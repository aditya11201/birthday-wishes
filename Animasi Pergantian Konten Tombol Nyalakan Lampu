  deleteTextAnimated(element) {
    return new Promise((resolve) => {
      let text = element.textContent;
      if (!text.length) {
        resolve();
        return;
      }
      const interval = setInterval(() => {
        text = text.slice(0, -1);
        element.textContent = text;
        if (!text.length) {
          clearInterval(interval);
          resolve();
        }
      }, 35);
    });
  }

