    }

    // --- Simple Balloons ---
    if (screen.showBalloons && !this.simpleBalloonsCreated) {
      this.createSimpleBalloons();
      balloonContainer.classList.add("active");
    } else if (screen.showBalloons) {
      balloonContainer.classList.add("active");
    } else {
      balloonContainer.classList.remove("active");
    }

