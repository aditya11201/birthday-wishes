    const centerX = window.innerWidth / 2;
    const centerY = window.innerHeight / 2;
    const radiusXTop = 280;
    const radiusYTop = 130;

    balloons.forEach((b, index) => {
      const rect = b.getBoundingClientRect();
      b.style.left = rect.left + "px";
