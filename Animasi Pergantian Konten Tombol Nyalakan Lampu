      const finalY = centerY - 100;
      b.style.left = finalX + "px";
      b.style.top = finalY + "px";
    }
  });

  // After cake fades, show typewriter
  setTimeout(() => {
    cake.style.display = "none";
    typewriterArea.classList.add("active");
    startTypewriterSequence();
  }, 800);
}

