      b.style.left = finalX + "px";
      b.style.top = finalY + "px";
      b.style.transform = "scale(1.2)";
      b.style.zIndex = "30";

      // Reveal letter text after convergence
      setTimeout(() => {
        const text = b.querySelector(".balloon-text");
        if (text) text.classList.add("visible");
      }, 1400);
