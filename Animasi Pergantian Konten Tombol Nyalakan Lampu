  { dur: "8.3s, 14.1s", delay: "-3.2s, -7.8s" },
  { dur: "10.4s, 7.2s", delay: "-5.1s, -4.6s" },
  { dur: "7.9s, 12.8s", delay: "-1.9s, -0.9s" },
  { dur: "13.2s, 10.1s", delay: "-8.2s, -6.3s" },
  { dur: "9.7s, 11.9s", delay: "-4.1s, -5.8s" },
