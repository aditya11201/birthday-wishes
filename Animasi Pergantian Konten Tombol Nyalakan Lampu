    -moz-osx-font-smoothing: grayscale;
}

img {
    max-width: 100%;
    height: auto;
    display: block;
}

button {
    cursor: pointer;
    border: none;
    background: none;
    font: inherit;
    color: inherit;
}

/* --------------------------------------------------------------------------
   3. Material Symbols
   -------------------------------------------------------------------------- */
