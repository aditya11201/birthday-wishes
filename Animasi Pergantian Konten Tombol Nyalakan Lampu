    } else {
      // Button is visible in waiting state — fade out text, swap, fade in
      iconEl.style.transition = "opacity 0.2s ease";
      labelEl.style.transition = "opacity 0.2s ease";
      iconEl.style.opacity = "0";
      labelEl.style.opacity = "0";
      setTimeout(() => {
