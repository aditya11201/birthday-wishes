/** Balloon animation durations and delays for each letter */
const BALLOON_TIMINGS = [
  { dur: "9.1s, 11.2s", delay: "-1.2s, -0.5s" },
  { dur: "7.5s, 13.4s", delay: "-2.3s, -3.1s" },
